{
    "name": "txtmsg/sms-client",
    "description": "Laravel SDK for txtmsg.lk SMS Gateway",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Txtmsg\\SmsClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Txtmsg\\SmsClient\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Txtmsg\\SmsClient\\SmsClientServiceProvider"
            ],
            "aliases": {
                "Txtmsg": "Txtmsg\\SmsClient\\Facades\\Txtmsg"
            }
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^13.0",
        "illuminate/http": "^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
